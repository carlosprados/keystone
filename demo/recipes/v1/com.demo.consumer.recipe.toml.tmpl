[metadata]
name = "com.demo.consumer"
version = "1.0.0"
description = "Demo data-consumer v1"
publisher = "keystone-demo"

[[dependencies]]
name = "com.demo.config"
version = "1.0.0"
type = "hard"

[[dependencies]]
name = "com.demo.producer"
version = "1.0.0"
type = "hard"

[[artifacts]]
uri = "http://localhost:9000/data-consumer-v1"
sha256 = "{{SHA256}}"

[lifecycle.install]
script = """
cp ../../../artifacts/com.demo.consumer/1.0.0/data-consumer-v1 ./app
chmod +x ./app
"""

[lifecycle.run]
restart_policy = "on-failure"
max_retries = 3

[lifecycle.run.exec]
command = "./app"

[lifecycle.run.exec.env]
CONSUMER_ADDR = ":7003"
CONFIG_URL = "http://localhost:7001/config"
PRODUCER_URL = "http://localhost:7002/events"

[lifecycle.run.health]
check = "http://localhost:7003/healthz"
interval = "3s"
timeout = "2s"
failure_threshold = 3
